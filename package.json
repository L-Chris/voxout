{
  "name": "voxout",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Provider gateway for speech synthesis, sound effects, and ASR.",
  "main": "./dist/server.js",
  "scripts": {
    "build": "npm run build:server && npm run build:web",
    "build:server": "prisma generate && tsc -p tsconfig.json",
    "build:web": "vite build --config frontend/vite.config.js",
    "test": "npm run build && node --test tests/*.test.mjs",
    "start": "node dist/server.js",
    "dev": "vite --config frontend/vite.config.js --host 0.0.0.0",
    "dev:server": "tsc -w -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/koa": "^3.0.3",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@koa/router": "^15.6.0",
    "@prisma/client": "^6.19.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "koa": "^3.2.1",
    "koa-bodyparser": "^4.4.1",
    "node-edge-tts": "^1.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reflect-metadata": "^0.2.2",
    "routing-controllers": "^0.11.3",
    "typedi": "^0.10.0",
    "ws": "^8.21.0"
  }
}
