generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model ProviderConfig {
  id          String   @id @default(cuid())
  provider_id String   @unique
  enabled     Boolean  @default(true)
  config      Json?
  secrets     Json?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([enabled])
}

model ProviderApiKey {
  id          String   @id @default(cuid())
  provider_id String
  name        String
  api_key     String   @db.Text
  weight      Int      @default(1)
  enabled     Boolean  @default(true)
  metadata    Json?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([provider_id])
  @@index([enabled])
}

model Voice {
  id                String   @id @default(cuid())
  voice_id          String   @unique
  name              String
  description       String?  @db.Text
  language          String?
  preview_mime_type String?
  preview_audio     String?  @db.LongText
  metadata          Json?
  provider_links    VoiceProviderLink[]
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
}

model VoiceProviderLink {
  id                  String   @id @default(cuid())
  voice_record_id     String
  voice               Voice    @relation(fields: [voice_record_id], references: [id], onDelete: Cascade)
  provider_id         String
  provider_account_id String   @default("default")
  provider_voice_id   String?
  provider_voice_key  String
  preview_mime_type   String?
  preview_audio       String?  @db.LongText
  metadata            Json?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@index([provider_id])
  @@index([voice_record_id])
  @@unique([voice_record_id, provider_id, provider_account_id])
  @@unique([provider_id, provider_account_id, provider_voice_key])
}
