PORT=4177
TTS_AUDIO_DIR=./audio
TTS_SYNTHESIS_TIMEOUT_MS=45000
TTS_SYNTHESIS_RETRIES=1

# Provider defaults are selected by the client request. Use provider=mimo from rebook to enable MiMo.
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_TTS_MODEL=mimo-v2.5-tts
MIMO_VOICE_DESIGN_MODEL=mimo-v2.5-tts-voicedesign
MIMO_VOICE_CLONE_MODEL=mimo-v2.5-tts-voiceclone
MIMO_VOICE_SAMPLE_TEXT=你好，我会用这个声音为角色说话。
MIMO_TTS_FORMAT=wav
MIMO_TTS_TIMEOUT_MS=45000
MIMO_OPTIMIZE_TEXT_PREVIEW=true

EDGE_TTS_TIMEOUT_MS=30000
EDGE_TTS_VOICES_CACHE_MS=86400000
EDGE_TTS_VOICES_TIMEOUT_MS=10000
